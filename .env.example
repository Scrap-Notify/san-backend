# PostgreSQL Configuration
DB_PASSWORD=db_password

# JWT secret
JWT_SECRET=jwt_secret_key

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth Login Policy
AUTH_LOGIN_MAX_FAIL_COUNT=5
AUTH_LOGIN_FAIL_WINDOW_SECONDS=300
AUTH_LOGIN_LOCK_DURATION_SECONDS=900

# GitHub OAuth
GITHUB_CLIENT_ID=github_client_id
GITHUB_CLIENT_SECRET=github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/github/callback
GITHUB_SCOPE=read:user,repo
GITHUB_SUCCESS_REDIRECT_URI=http://localhost:5173/auth/github/success
GITHUB_FAILURE_REDIRECT_URI=http://localhost:5173/auth/github/failure
